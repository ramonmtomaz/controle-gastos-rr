# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# ─── Google Sheets ────────────────────────────────────────────────────────────
# ID da planilha: o código na URL  docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=1QsMR3gFz4EPNmXZzGQPV9H58PDGZn9ZeVbx78Jz-M9M
# Nome da aba dentro da planilha (padrão: Gastos)
SHEET_NAME=Gastos

# ─── Sessão ───────────────────────────────────────────────────────────────────
# Gere uma string aleatória segura (ex: openssl rand -base64 32)
SESSION_SECRET=uma_string_aleatoria_longa

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL do frontend (em produção: URL do GitHub Pages)
FRONTEND_URL=http://localhost:5500

# ─── Acesso restrito ──────────────────────────────────────────────────────────
# E-mails autorizados a acessar o site (separados por vírgula)
# Deixe vazio para permitir qualquer e-mail Google
ALLOWED_EMAILS=ramonmadeira5@gmail.com

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
