# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=640940450307-mkhdpenthjtt7cful39it0io3ls5erc6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# ─── Conta de Serviço Google ──────────────────────────────────────────────────
# Cole aqui o conteúdo JSON COMPLETO da chave da service account (em uma linha)
# Obtenha em: Google Cloud Console → IAM → Contas de serviço → Chaves → JSON
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"SEU_PROJETO",...}

# ─── Master Spreadsheet ────────────────────────────────────────────────────────
# Planilha mestra que serve como banco de dados do sistema
# Crie uma planilha em branco no Google Drive, compartilhe com o e-mail da service
# account (editor), e cole o ID aqui.
# Depois acesse: GET /controles/setup para criar as abas automaticamente.
MASTER_SPREADSHEET_ID=SEU_MASTER_SPREADSHEET_ID

# ─── Sessão ───────────────────────────────────────────────────────────────────
# Gere uma string aleatória segura (ex: openssl rand -base64 32)
SESSION_SECRET=uma_string_aleatoria_longa

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL do frontend (em produção: URL do GitHub Pages)
FRONTEND_URL=http://localhost:5500

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
